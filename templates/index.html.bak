<!DOCTYPE html>
<html>
	<head>
		<title>Fishbowl game</title>
		<script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
	</head>
	<body>
		<h1>Play fishbowl</h1>
		<p>Enter Text</p>
		<form action="/action_page.php">
			<label for="phrase">Phrase:</label>
			<input type="text" id="phrase" name="phrase"><br><br>
			<button hx-post="/phrase">Submit</button>
		</form>

		<button hx-get="/start">Start game</button>
		<p>Take round</p>
		<p id="turn-phrase"></p>
		<button hx-get="/turn" hx-target="#turn-phrase" hx-swap="innerText">
			Draw phrase
		</button>
	</body>
</html>
